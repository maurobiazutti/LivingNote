<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Living Note" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Living Note">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-900 text-gray-100 min-h-screen">
    <% if user_signed_in? %>
      <div data-controller="sidebar" class="flex min-h-screen overflow-hidden">
        <!-- SIDEBAR -->
        <aside 
  data-sidebar-target="container"
  class="fixed inset-y-0 left-0 z-40 w-64 md:w-64 bg-gray-950 border-r border-gray-800 flex flex-col justify-between transition-all duration-300 transform -translate-x-full md:translate-x-0 md:static md:h-screen overflow-hidden"
>
          <!-- Seção Superior -->
          <div class="p-4 md:p-5">
            <!-- Header da Sidebar com botão de fechar/abrir -->
            <div class="flex items-center justify-between gap-2 min-h-[40px]">
              <h2 class="sidebar-text text-2xl font-bold text-emerald-400 flex items-center gap-2 truncate transition-opacity duration-200">
                LivingNote 📓
              </h2>
              <!-- Botão de colapso visível apenas no Desktop -->
              <button 
                data-action="click->sidebar#toggle" 
                class="hidden md:flex items-center justify-center w-10 h-10 rounded-xl text-gray-400 hover:text-white hover:bg-gray-900 transition cursor-pointer mx-auto"
                title="Alternar menu"
                >
                <span class="sidebar-toggle-icon text-lg">◀</span>
              </button>
            </div>
            <p class="sidebar-text text-xs text-gray-500 mt-1 transition-opacity duration-200">Seu ecossistema pessoal</p>
            <!-- Menu de Navegação -->
            <nav class="mt-8 space-y-2">
              <%= link_to root_path, class: "flex items-center gap-4 px-4 py-3 text-sm font-medium rounded-xl text-gray-300 hover:bg-gray-900 hover:text-white transition", title: "Home / Dashboard" do %>
                <span class="text-xl flex-shrink-0">🏠</span>
                <span class="sidebar-text truncate transition-opacity duration-200">Home / Dashboard</span>
              <% end %>
              <div class="sidebar-text pt-4 text-[10px] font-semibold text-gray-600 uppercase tracking-wider px-4 transition-opacity duration-200">Módulos</div>
              <a href="#" class="flex items-center gap-4 px-4 py-3 text-sm font-medium rounded-xl text-gray-500 hover:bg-gray-900/50 hover:text-gray-300 transition" title="Finanças">
                <span class="text-xl flex-shrink-0">💰</span>
                <span class="sidebar-text truncate transition-opacity duration-200">Finanças (Breve)</span>
              </a>
              <a href="#" class="flex items-center gap-4 px-4 py-3 text-sm font-medium rounded-xl text-gray-500 hover:bg-gray-900/50 hover:text-gray-300 transition" title="Meus Currículos">
                <span class="text-xl flex-shrink-0">📄</span>
                <span class="sidebar-text truncate transition-opacity duration-200">Meus Currículos</span>
              </a>
            </nav>
          </div>
          <!-- Rodapé da Sidebar -->
          <div class="p-4 border-t border-gray-800 bg-gray-950/50">
            <div class="sidebar-text px-2 mb-3 transition-opacity duration-200">
              <p class="text-xs text-gray-500">Logado como:</p>
              <p class="text-sm font-medium text-gray-300 truncate"><%= current_user.email %></p>
            </div>
            <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center justify-center gap-4 px-4 py-3 bg-red-950/30 hover:bg-red-900/40 text-red-400 hover:text-red-300 border border-red-900/30 rounded-xl transition text-sm font-medium cursor-pointer", title: "Sair do sistema" do %>
              <span class="text-xl flex-shrink-0">🚪</span>
              <span class="sidebar-text truncate transition-opacity duration-200">Sair</span>
            <% end %>
          </div>
        </aside>
        <!-- CONTEÚDO PRINCIPAL -->
        <div class="flex-1 flex flex-col min-w-0">
          <!-- BARRA DE TOPO (Exclusiva Mobile - md:hidden esconde no desktop) -->
          <header class="flex items-center justify-between px-6 py-4 bg-gray-950 border-b border-gray-800 md:hidden">
            <h1 class="text-xl font-bold text-emerald-400">LivingNote 📓</h1>
            <!-- Botão Hambúrguer Mobile -->
            <button 
              data-action="click->sidebar#toggle" 
              class="p-2 rounded-lg text-gray-400 hover:bg-gray-900 focus:outline-none cursor-pointer"
              >
              <span class="text-xl">☰</span>
            </button>
          </header>
          <!-- Área do conteúdo principal (Adicionada rolagem suave) -->
          <main class="flex-1 overflow-y-auto p-6 md:p-10">
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <!-- Layout deslogado -->
      <main class="w-full min-h-screen">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
