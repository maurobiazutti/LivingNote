<div class="bg-gray-900 min-h-screen flex items-center justify-center px-4">
  <div class="bg-gray-800/50 border border-gray-700/50 rounded-2xl p-8 shadow-xl backdrop-blur-sm max-w-md w-full">
    <h2 class="text-3xl font-extrabold text-emerald-400 mb-2">Entrar na sua conta</h2>
    <p class="text-gray-400 mb-6">Use seu e-mail e senha para acessar o LivingNote.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-5">
        <div>
          <%= f.label :email, class: "block text-gray-300 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-3 bg-gray-900/50 border border-gray-700 rounded-xl focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 text-white placeholder-gray-500 transition duration-150" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-gray-300 mb-2" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-3 bg-gray-900/50 border border-gray-700 rounded-xl focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 text-white placeholder-gray-500 transition duration-150" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-3 text-gray-300">
            <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-600 bg-gray-900 text-emerald-500 focus:ring-emerald-500" %>
            <%= f.label :remember_me, class: "text-gray-300" %>
          </div>
        <% end %>

        <div class="pt-2">
          <%= f.submit "Log in", class: "w-full text-center px-4 py-3 bg-emerald-600 hover:bg-emerald-500 active:scale-[0.98] rounded-xl transition duration-150 font-semibold shadow-lg shadow-emerald-950/30 text-white cursor-pointer" %>
        </div>
      </div>
    <% end %>

    <div class="mt-6 space-y-2 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
